# Streamlit secrets 範本。
#
# 本機開發：複製為 .streamlit/secrets.toml（已列入 .gitignore，不會被提交）。
#   （本機其實也可改用專案根目錄的 .env，兩者擇一即可。）
#
# Streamlit Cloud：不要上傳這個檔，改在 App 的「Settings → Secrets」貼上同樣內容。
#
# app 啟動時會把這些值橋接到環境變數，讓 config/settings.py 讀得到。

GOOGLE_MAPS_API_KEY = ""
GEMINI_API_KEY = ""
GEMINI_MODEL = "gemini-1.5-flash"
