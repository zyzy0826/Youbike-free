# Demo 金鑰只包含在作業提交的壓縮檔案中，並不包含在公開 Github 上

# Google Maps Platform 金鑰 —— 用於以真實道路距離校正騎乘時間
# 需啟用 Distance Matrix API / Directions API
GOOGLE_MAPS_API_KEY=

# Google Gemini 金鑰 —— AI 回饋語氣潤飾（客觀事實 → LLM 潤飾）
# 申請：https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
# 便宜快速的模型；可改為 gemini-2.5-flash 等
GEMINI_MODEL=gemini-1.5-flash
